{
  "name": "vimfields",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Vim keybindings for text fields in the browser",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "typecheck": "tsc --noEmit",
    "watch": "node esbuild.config.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:dom": "vitest run tests/dom/",
    "package": "npm run build && node scripts/package.mjs",
    "install:vivaldi": "npm run build && node scripts/install-vivaldi.mjs",
    "uninstall:vivaldi": "node scripts/install-vivaldi.mjs --uninstall"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@vitest/coverage-v8": "^3.1.0",
    "esbuild": "^0.24.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
